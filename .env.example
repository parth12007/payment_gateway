# Copy this file to `.env` and fill in real values. NEVER commit `.env`.

# --- App ---
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# --- Postgres ---
# When using docker-compose, host is `postgres`. When running natively, `localhost`.
DATABASE_URL=postgresql://payments:payments@localhost:5432/payments?schema=public

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Stripe ---
# Get these from https://dashboard.stripe.com/test/apikeys (TEST MODE).
# The publishable key (pk_test_...) is safe to expose to clients.
# The secret key (sk_test_...) is SERVER-ONLY. If it leaks, rotate immediately.
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
STRIPE_SECRET_KEY=sk_test_replace_me

# Get this from `stripe listen --forward-to localhost:3000/v1/webhooks/stripe`,
# or from the Stripe dashboard webhook endpoint config.
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Per-request timeout passed to the Stripe SDK (ms).
STRIPE_API_TIMEOUT_MS=10000

# --- Retry policy ---
MAX_ATTEMPTS=3
BACKOFF_BASE_MS=1000
BACKOFF_MAX_MS=60000
RETRY_WORKER_INTERVAL_MS=2000

# --- Rate limit (per-merchant token bucket on POST /v1/payments) ---
# Bucket holds RATE_LIMIT_CAPACITY tokens. Refills at RATE_LIMIT_REFILL_PER_SECOND.
# Defaults give 20-request burst, then steady-state 10/sec per merchant.
RATE_LIMIT_ENABLED=1
RATE_LIMIT_CAPACITY=20
RATE_LIMIT_REFILL_PER_SECOND=10

# --- Tests ---
# Set RUN_LIVE=1 to enable opt-in tests that hit real Stripe test mode.
RUN_LIVE=0
